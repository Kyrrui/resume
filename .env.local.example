# GitHub Personal Access Token used by scripts/fetch-github-activity.mjs at build
# time to populate the "Currently Building" section with your recent public AND
# private repos.
#
# Scopes required:
#   - repo            (read private repo metadata + commits)
#   - read:user
#
# Generate one at: https://github.com/settings/tokens
#
# Local dev:
#   1. Copy this file to .env.local
#   2. Fill in the token
#   3. Run `npm run fetch:github` to regenerate src/data/recent-repos.json
#
# Production (Netlify):
#   Set GITHUB_TOKEN as an environment variable in the Netlify site settings.
#   The `prebuild` npm script will use it automatically during deploys.

GITHUB_TOKEN=
